APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─────────────────────────────────────────────────────────────────────────────
# Database (MySQL 8)
# ─────────────────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1           # Hostname or IP address of the MySQL server
DB_PORT=3306                # TCP port the MySQL server listens on (default: 3306)
DB_DATABASE=file_storage    # Name of the MySQL database schema for this application
DB_USERNAME=laravel         # MySQL user account the application connects as
DB_PASSWORD=secret          # Password for the MySQL user account above

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ─────────────────────────────────────────────────────────────────────────────
# RabbitMQ message broker
# ─────────────────────────────────────────────────────────────────────────────
RABBITMQ_HOST=rabbitmq            # Hostname or IP address of the RabbitMQ server
RABBITMQ_PORT=5672                # AMQP port RabbitMQ listens on (default: 5672)
RABBITMQ_USER=guest               # RabbitMQ user account the application connects as
RABBITMQ_PASSWORD=guest           # Password for the RabbitMQ user account above
RABBITMQ_QUEUE=file_notifications # Name of the durable queue for deletion-event messages

# ─────────────────────────────────────────────────────────────────────────────
# Application-specific settings (config/filestorage.php)
# ─────────────────────────────────────────────────────────────────────────────
NOTIFY_EMAIL=admin@example.com  # Email address embedded in every RabbitMQ deletion-event message
MAX_UPLOAD_BYTES=10485760        # Maximum allowed upload file size in bytes (default: 10 MB)
RETENTION_HOURS=24               # Hours after upload before a file is eligible for auto-deletion
RATE_LIMIT_UPLOAD=20             # Max file-upload requests per IP per 60-second window
RATE_LIMIT_DELETE=30             # Max file-delete requests per IP per 60-second window
RATE_LIMIT_DOWNLOAD=60           # Max file-download requests per IP per 60-second window
PAGINATION_PER_PAGE=15           # Number of file records shown per page on the CRUD listing page
APP_PORT=8080                    # Host port mapped to the Laravel container (e.g. http://localhost:8080)
